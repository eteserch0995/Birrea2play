# Supabase Edge Functions — Secrets
# Configurar con: supabase secrets set KEY=value
# Nunca commitear este archivo con valores reales.

# Yappy — Botón de Pago V2 (obtener en Yappy Comercial > Métodos de cobro > Botón de Pago)
YAPPY_MERCHANT_ID=tu_merchant_id_aqui
YAPPY_SECRET_KEY=tu_secret_key_en_base64_aqui
YAPPY_DOMAIN=https://tu-dominio.com
YAPPY_IPN_URL=https://<ref>.supabase.co/functions/v1/yappy-ipn
