{
  "expo": {
    "name": "Birrea2Play",
    "slug": "birrea2play",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "birrea2play",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07101F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.birrea2play.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Birrea2Play necesita acceso a tu cámara para tu foto de perfil.",
        "NSPhotoLibraryUsageDescription": "Birrea2Play necesita acceso a tus fotos para tu foto de perfil.",
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "yappy.com.pa": {
              "NSIncludesSubdomains": true,
              "NSExceptionMinimumTLSVersion": "TLSv1.0",
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSRequiresCertificateTransparency": false
            },
            "api.yappy.com.pa": {
              "NSIncludesSubdomains": true,
              "NSExceptionMinimumTLSVersion": "TLSv1.0",
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSRequiresCertificateTransparency": false
            }
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07101F"
      },
      "package": "com.birrea2play.app",
      "newArchEnabled": true,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "0bc6b976-48cd-4904-b716-3a7446b5b83d"
      }
    },
    "plugins": [
      "expo-system-ui",
      [
        "expo-image-picker",
        {
          "photosPermission": "Birrea2Play necesita acceso a tus fotos para tu foto de perfil."
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#C8102E",
          "sounds": []
        }
      ]
    ],
    "owner": "serch0995",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0bc6b976-48cd-4904-b716-3a7446b5b83d"
    }
  }
}
